---
import DiagramBoxLabel from "./DiagramBoxLabel.astro";

const inputs = ["Git repos", "Jira", "Confluence", "PDFs", "Documents", "Images", "Diagrams"];
const pipeline = ["Discovery", "Sync", "Normalize", "Parse", "Metadata", "Organize", "Assess"];
const outputs = [
  "Architecture views",
  "Dependencies",
  "Modernization backlog",
  "Onboarding context",
  "Human-reviewed recommendations",
];
---

<figure class="diagram">
  <svg viewBox="0 0 780 420" role="img" aria-labelledby="ctx-title ctx-desc">
    <title id="ctx-title">Context-ingestion pipeline</title>
    <desc id="ctx-desc">
      Inputs from repositories and delivery systems flow through discovery, synchronization,
      normalization, parsing, metadata, organization, and assessment, producing architecture views
      and human-reviewed recommendations.
    </desc>
    <rect width="780" height="420" fill="#101010" rx="8"></rect>
    <text x="40" y="36" fill="#6ea8a0" font-family="ui-monospace, monospace" font-size="12">
      INPUTS
    </text>
    {
      inputs.map((label, i) => {
        const x = 30 + i * 105;
        const y = 50;
        const w = 95;
        const h = 40;
        return (
          <g>
            <rect x={x} y={y} width={w} height={h} rx="4" fill="#141414" stroke="#333" />
            <DiagramBoxLabel
              x={x}
              y={y}
              width={w}
              height={h}
              label={label}
              fontSize={10}
              color="#cfcfc8"
            />
          </g>
        );
      })
    }
    <text x="40" y="130" fill="#6ea8a0" font-family="ui-monospace, monospace" font-size="12">
      PIPELINE
    </text>
    {
      pipeline.map((label, i) => {
        const x = 30 + i * 105;
        const y = 150;
        const w = 95;
        const h = 42;
        return (
          <g>
            <rect
              x={x}
              y={y}
              width={w}
              height={h}
              rx="4"
              fill="rgba(110,168,160,0.12)"
              stroke="#6ea8a0"
              stroke-opacity="0.5"
            />
            <DiagramBoxLabel x={x} y={y} width={w} height={h} label={label} fontSize={11} />
            {i < pipeline.length - 1 && (
              <path d={`M ${125 + i * 105} 171 L ${135 + i * 105} 171`} stroke="#6ea8a0" />
            )}
          </g>
        );
      })
    }
    <text x="40" y="240" fill="#6ea8a0" font-family="ui-monospace, monospace" font-size="12">
      OUTPUTS
    </text>
    {
      outputs.map((label, i) => {
        const x = 30 + (i % 5) * 145;
        const y = 260;
        const w = 135;
        const h = 56;
        return (
          <g>
            <rect x={x} y={y} width={w} height={h} rx="4" fill="#141414" stroke="#333" />
            <DiagramBoxLabel
              x={x}
              y={y}
              width={w}
              height={h}
              label={label}
              fontSize={10}
              color="#cfcfc8"
            />
          </g>
        );
      })
    }
    <text
      x="40"
      y="360"
      fill="#9a9a96"
      font-size="11"
      font-family="ui-sans-serif, system-ui, sans-serif"
    >
      Foundation for AI-enabled modernization — human review remains the authority for intent.
    </text>
  </svg>
  <figcaption class="diagram__caption">
    Context-ingestion pipeline from fragmented sources to human-reviewed architecture outputs.
  </figcaption>
</figure>
