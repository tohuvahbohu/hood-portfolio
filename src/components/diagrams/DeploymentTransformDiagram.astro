---
import DiagramBoxLabel from "./DiagramBoxLabel.astro";

const before = [
  "Manual preparation",
  "Environment coordination",
  "Installation steps",
  "Configuration",
  "Validation",
  "Delays & rework",
];
const after = [
  "Validated package",
  "Automated env prep",
  "Automated installation",
  "Configuration apply",
  "Verification",
  "~1 hour completion",
];

const boxW = 110;
const boxH = 56;
---

<figure class="diagram">
  <svg viewBox="0 0 760 380" role="img" aria-labelledby="deploy-title deploy-desc">
    <title id="deploy-title">Deployment transformation before and after</title>
    <desc id="deploy-desc">
      Before path shows multi-step manual installation with delays. After path shows automated
      package through verification completing in approximately one hour.
    </desc>
    <rect width="760" height="380" fill="#101010" rx="8"></rect>
    <text x="40" y="36" fill="#c46b6b" font-family="ui-monospace, monospace" font-size="12">
      BEFORE — months
    </text>
    {
      before.map((label, i) => {
        const x = 30 + i * 120;
        const y = 50;
        return (
          <g>
            <rect
              x={x}
              y={y}
              width={boxW}
              height={boxH}
              rx="4"
              fill="#1a1010"
              stroke="#c46b6b"
              stroke-opacity="0.5"
            />
            <DiagramBoxLabel
              x={x}
              y={y}
              width={boxW}
              height={boxH}
              label={label}
              fontSize={10}
              color="#e8e8e4"
            />
          </g>
        );
      })
    }
    <text x="40" y="150" fill="#6ea8a0" font-family="ui-monospace, monospace" font-size="12">
      AFTER — approximately one hour
    </text>
    {
      after.map((label, i) => {
        const x = 30 + i * 120;
        const y = 168;
        return (
          <g>
            <rect
              x={x}
              y={y}
              width={boxW}
              height={boxH}
              rx="4"
              fill="rgba(110,168,160,0.12)"
              stroke="#6ea8a0"
              stroke-opacity="0.55"
            />
            <DiagramBoxLabel
              x={x}
              y={y}
              width={boxW}
              height={boxH}
              label={label}
              fontSize={10}
              color="#e8e8e4"
            />
          </g>
        );
      })
    }
    <text x="40" y="280" fill="#9a9a96" font-size="12" font-family="system-ui, sans-serif">
      Architecture impact on the operating model — not only software structure.
    </text>
  </svg>
  <figcaption class="diagram__caption">
    Retail installation transformation from multi-month manual process to approximately one-hour
    automated completion.
  </figcaption>
</figure>
