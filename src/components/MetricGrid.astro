---
import { getHomepageMetrics, healthcareEstateNarrative } from "../data/metrics";
const metrics = getHomepageMetrics();
---

<section class="section" id="outcomes" aria-labelledby="outcomes-heading">
  <div class="container">
    <p class="section-label">Outcomes</p>
    <h2 class="section-title" id="outcomes-heading">Architecture outcomes that change delivery</h2>
    <p class="section-lead">
      High-signal results from enterprise estate work, client integration productization, and
      deployment transformation. Figures are provided for verification before publication.
    </p>

    <div class="metric-grid">
      {
        metrics.map((m) => (
          <article class="metric-card" data-reveal>
            <p class="metric-card__value">{m.value}</p>
            <p class="metric-card__label">{m.label}</p>
          </article>
        ))
      }
    </div>
    <p class="metric-note" data-reveal>
      {healthcareEstateNarrative}
    </p>
  </div>
</section>
