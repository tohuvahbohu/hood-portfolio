---
import { profile } from "../data/profile";
import Portrait from "./Portrait.astro";
const { hero } = profile;
---

<section class="hero grid-bg" id="overview" aria-labelledby="hero-heading">
  <div class="container hero__grid">
    <div class="hero__content">
      <p class="eyebrow">{profile.eyebrow}</p>
      <h1 id="hero-heading">{hero.primaryHeadline}</h1>
      <p class="hero__support">{hero.supportingCopy}</p>
      <p class="hero__line">{hero.supportingLine}</p>
      <div class="hero__actions">
        <a class="btn btn-primary" href={hero.primaryCta.href}>{hero.primaryCta.label}</a>
        <a class="btn btn-secondary" href={hero.secondaryCta.href}>{hero.secondaryCta.label}</a>
        <a class="btn btn-ghost" href={hero.tertiaryCta.href}>{hero.tertiaryCta.label}</a>
      </div>
      <ul class="hero__meta">
        <li>{profile.location}</li>
        <li>{profile.workMode}</li>
        <li>{profile.travel}</li>
        {profile.showAvailability && <li>{profile.availabilityLabel}</li>}
      </ul>
    </div>

    <aside class="hero__identity" aria-label="Profile">
      <div class="hero__portrait-frame">
        <Portrait size="xl" shape="soft" priority class="hero__portrait" />
      </div>
      <div class="hero__identity-copy">
        <p class="hero__identity-name">{profile.name}</p>
        <p class="hero__identity-role">Principal Software Architect</p>
        <p class="hero__identity-focus">
          Enterprise architecture · SaaS modernization · .NET / Azure · AI-enabled SDLC
        </p>
      </div>
    </aside>
  </div>
</section>
